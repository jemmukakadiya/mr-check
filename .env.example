# ─────────────────────────────────────────────────────────────────────────────
# mr check — configuration template
#
# Copy this file to `.env` (same directory) and fill in the values.
# `.env` is gitignored; `.env.example` is committed.
#
# Resolution order for every key below:
#   1. Already-set environment variable (e.g. `export GITLAB_TOKEN=…`)
#   2. Value from .env
#   3. Built-in default in the script (where one exists)
#
# A `KEY=` line with an empty value behaves the same as "not set".
# ─────────────────────────────────────────────────────────────────────────────


# ── Required ────────────────────────────────────────────────────────────────

# GitLab Personal Access Token. Needs the `api` scope so the script can
# read MRs, upload to /uploads, and post notes.
#
# To copy from the macOS Keychain into this file:
#   security find-generic-password -s 'claude gilab token ' -w
#
# Never commit the real value. Rotate by re-issuing the PAT in GitLab.
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx


# ── Optional (sensible defaults exist) ──────────────────────────────────────

# GitLab base URL — no trailing slash.
# Default: https://gitlab.lrz.de
GITLAB_URL=https://gitlab.lrz.de

# Project path in `namespace/name` form (NOT URL-encoded — the script
# URL-encodes it where needed).
# Default: politeia/koinon
GITLAB_PROJECT=politeia/koinon

# MR label that gates which MRs the script looks at.
# Default: Team Jemish
MR_LABEL=Team Jemish

# Override where state.json, logs/, and pending/ live.
# Default: ~/.koinon-mr-reviews
# MR_REVIEW_ROOT=/Users/jemmu/.koinon-mr-reviews

# Override where rendered PDFs are written.
# Default: ~/mr reviews
# MR_REVIEW_PDF_DIR=/Users/jemmu/mr reviews
